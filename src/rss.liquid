---
permalink: rss.xml
---

<?xml version="1.0" encoding="UTF-8"?>
<rss xmlns:atom="http://www.w3.org/2005/Atom" version="2.0">
    <channel>
        <title>忍狐のホームページ</title>
        <link>https://ninko.cc/</link>
        <description>ninko.cc で公開中の個人サイトです</description>
        <atom:link href="https://ninko.cc/rss.xml" rel="self" type="application/rss+xml" />

        {% assign posts = collections.posts | reverse %}
        {% for post in posts limit:10 %}
            <item>
                <title>{{ post.data.rss.title }}</title>
                <pubDate>{{ post.date | rfc822 }}</pubDate>
                <link>{{ "https://ninko.cc" | append: post.data.path }}</link>
                <guid isPermaLink="false">{{ post.data.rss.hash }}</guid>
                <description>{{ post.data.head }}</description>
            </item>
        {% endfor %}
    </channel>
</rss>
